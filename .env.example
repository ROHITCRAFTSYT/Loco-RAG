# ---- LLM providers (both expose an OpenAI-compatible /v1 API) ----
# When running the backend in Docker, use host.docker.internal to reach apps on your host.
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.1

# ---- Embeddings (local) ----
# fastembed = bundled ONNX model (no extra setup); ollama = use a pulled embed model
EMBED_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---- Vector store ----
VECTOR_BACKEND=chroma          # chroma | lancedb
DEFAULT_COLLECTION=default

# ---- RAG ----
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
RETRIEVE_TOP_K=8
RERANK_TOP_N=4
ENABLE_RERANK=false

# ---- Memory ----
MEMORY_SUMMARIZE_AFTER_TOKENS=3000

# ---- Web search ----
WEBSEARCH_PROVIDER=duckduckgo   # duckduckgo | searxng
SEARXNG_BASE_URL=http://localhost:8080
WEBSEARCH_MAX_RESULTS=5

# ---- Voice (local speech-to-text via faster-whisper) ----
WHISPER_MODEL=base              # tiny | base | small | medium | large-v3

# ---- Server / storage (uncomment to override defaults in app/config.py) ----
# CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
# DATA_DIR=./data
# DATABASE_URL=sqlite:///./data/app.db
# CHROMA_DIR=./data/chroma
# LANCEDB_DIR=./data/lancedb
